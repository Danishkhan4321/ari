# Ari - dashboard environment
NODE_ENV=development
DATABASE_URL=postgres://ari:ari@localhost:5432/ari
DASHBOARD_BASE_URL=http://127.0.0.1:43101
BOT_INTERNAL_URL=http://127.0.0.1:43100
INTERNAL_API_SECRET=replace-with-a-long-random-string
# Use the identical absolute, writable path configured for the Ari backend.
# Relative values resolve from different working directories and must not be used.
ARI_SESSION_ATTACHMENT_DIR=
LEAD_ENRICHMENT_ENABLED=false
LEAD_ENRICHMENT_ALLOWLIST=
LEAD_ENRICHMENT_DAILY_BUDGET_USD=5
LEAD_ENRICHMENT_MONTHLY_BUDGET_USD=25
# E.164 digits only (no +), e.g. 918448089096 for +91 84480 89096
DASHBOARD_WHATSAPP_NUMBER=
