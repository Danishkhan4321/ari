# Public hostnames. A free hackathon option is app.<STATIC-IP>.sslip.io and
# api.<STATIC-IP>.sslip.io after replacing dots in the IP with dashes.
ARI_DASHBOARD_HOST=app.203-0-113-10.sslip.io
ARI_API_HOST=api.203-0-113-10.sslip.io
ARI_TLS_EMAIL=you@example.com

APP_BASE_URL=https://api.203-0-113-10.sslip.io
DASHBOARD_BASE_URL=https://app.203-0-113-10.sslip.io
GOOGLE_DASHBOARD_REDIRECT_URI=https://app.203-0-113-10.sslip.io/api/auth/google/callback
BOT_INTERNAL_URL=http://backend:3000

# Use the existing managed PostgreSQL/Supabase database; do not run Postgres
# on the small Lightsail instance.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
INTERNAL_API_SECRET=replace-with-at-least-32-random-characters
INTERNAL_API_ALLOW_PRIVATE=1
ENCRYPTION_KEY=replace-with-a-32-byte-key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ARI_SESSION_DAYS=365
ARI_DESKTOP_AUTH_BYPASS=false

# Add the AI/provider credentials that the hackathon demo actually uses.
LLM_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
