{
  "name": "ari-desktop",
  "version": "0.2.1",
  "private": true,
  "author": "Ari",
  "description": "Local Electron desktop shell for Ari",
  "main": "src/main.js",
  "scripts": {
    "predev": "node scripts/migrate.js",
    "dev": "electron .",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "prepare:hosted-build": "node scripts/write-build-config.js",
    "build:win": "npm run prepare:hosted-build && electron-builder --win nsis --x64",
    "release:win": "npm run prepare:hosted-build && electron-builder --win nsis --x64 --publish always",
    "build:mac-helper": "node scripts/build-macos-capture.js",
    "build:mac": "npm run build:mac-helper && electron-builder --mac dmg zip --x64 --arm64"
  },
  "dependencies": {
    "active-win": "^9.0.0",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.6.2",
    "tree-kill": "^1.2.2",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "tar": "7.5.20"
  },
  "build": {
    "appId": "com.ari.desktop",
    "productName": "Ari",
    "protocols": [
      {
        "name": "Ari sign-in",
        "schemes": [
          "ari"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/active-win/**/*",
      "node_modules/uiohook-napi/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/app-config.json",
        "to": "app-config.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Danishkhan4321",
        "repo": "ari"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "Ari records system audio when you choose Record Meeting.",
        "NSMicrophoneUsageDescription": "Ari uses your microphone when you record a meeting or start voice dictation."
      },
      "extraResources": [
        {
          "from": "build/native/macos",
          "to": "native/macos",
          "filter": [
            "ari-meeting-capture"
          ]
        }
      ]
    }
  }
}
