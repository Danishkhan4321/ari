# Ari - bot/API environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://ari:ari@localhost:5432/ari?sslmode=disable
DATABASE_SSL=false

# Primary AI provider for compatibility/single-shot calls
# (gemini | openai | openrouter | groq | bedrock | fireworks | vertex_gemma)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Ari primary multi-step runtime: provider-neutral Agno 2.7.4. Leave the model
# provider blank to choose OpenRouter when its key exists, otherwise Gemini.
# Direct Codex login remains a separate desktop App Server runtime.
# Agent runtime: native (in-process Node loop on direct Vertex/Gemini —
# fastest, recommended) | agno (Python sidecar; also the multimodal fallback
# for file turns under native) | openrouter | anything else = legacy loop.
ARI_AGENT_RUNTIME=agno
# Native runtime model + knobs (native only):
#   ARI_NATIVE_MODEL_ID=gemini-2.5-flash   (falls back to MODEL_AGENT_PRIMARY)
#   ARI_NATIVE_MAX_MODEL_ROUNDS=6
#   ARI_TOOL_SEMANTIC=on   (opt back into embedding-based tool retrieval)
ARI_AGNO_MODEL_PROVIDER=
ARI_AGNO_MODEL_ID=
ARI_AGNO_PYTHON=python
ARI_AGNO_WORKER=agno_runtime/worker.py
ARI_AGNO_DB_SCHEMA=public
ARI_AGNO_SESSION_TABLE=ari_agno_sessions
ARI_AGNO_MEMORY_TABLE=ari_agno_memories
ARI_AGNO_METRICS_TABLE=ari_agno_metrics
ARI_AGNO_EVAL_TABLE=ari_agno_eval_runs
ARI_AGNO_HISTORY_RUNS=4
ARI_AGNO_HISTORY_TOOL_CALLS=12
ARI_AGNO_SESSION_SUMMARIES=true
ARI_PROVIDER_SUMMARY_MIN_MESSAGES=12
ARI_PROVIDER_SUMMARY_REFRESH_MESSAGES=6
ARI_PROVIDER_SUMMARY_HISTORY_LIMIT=80
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODELS=openai/gpt-4.1-mini,google/gemini-2.5-flash
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Ari
OPENROUTER_ZDR=true
OPENROUTER_DENY_DATA_COLLECTION=true
OPENROUTER_REQUIRE_PARAMETERS=true
OPENROUTER_ALLOW_FALLBACKS=true
# Direct @openrouter/agent compatibility runtime only. Agno model providers do
# not consume this compatibility-only override.
OPENROUTER_REASONING_EFFORT=
ARI_AGENT_MAX_STEPS=10
ARI_AGENT_MAX_TOKENS=20000
ARI_AGENT_MAX_COST_USD=0.50
ARI_AGENT_MAX_TOOL_CALLS=12
ARI_AGENT_MAX_OUTPUT_TOKENS=2500
# Five minutes per resumable segment. Known capacity stops automatically
# continue in the same durable conversation; unknown side effects never replay.
ARI_AGENT_TIMEOUT_MS=300000
ARI_CODEX_TURN_TIMEOUT_MS=300000
ARI_AGENT_MAX_CONTINUATIONS=3
ARI_TOOL_TIMEOUT_MS=300000
ARI_AGENT_REQUEST_TIMEOUT_MS=45000
# Bounded durable working context. Canonical conversation_history remains full.
ARI_AGENT_STATE_MAX_ITEMS=120
ARI_AGENT_STATE_MAX_CHARS=120000
ARI_AGENT_CHECKPOINT_CHARS=12000
ARI_AGENT_HISTORY_RECONCILE_LIMIT=500
ARI_AGENT_TOOL_LIMIT=24
AI_SESSION_GAP_MINUTES=60

# ── Vertex-served Google models (Gemma MaaS or first-party Gemini) ──────
# Recommended agent-loop setup on GCP credits: LLM_PROVIDER=vertex_gemma with
# Gemini models (first-class NATIVE tool calling — far more reliable than
# Gemma for tool selection). gemini-* routes through Vertex whenever
# LLM_PROVIDER=vertex_gemma, even if GEMINI_API_KEY is also set.
#   LLM_PROVIDER=vertex_gemma
#   ARI_AGNO_MODEL_PROVIDER=gemini
#   ARI_AGNO_MODEL_ID=gemini-2.5-flash
#   ARI_AGNO_GEMINI_VERTEX=true
#   GOOGLE_VERTEX_PROJECT=my-gcp-project
#   VERTEX_GEMMA_MODEL=gemini-2.5-flash
#   MODEL_AGENT_PRIMARY=gemini-2.5-flash
#   AGENT_COMPLEX_MODEL=gemini-2.5-pro
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VERTEX_CREDENTIALS=
ARI_AGNO_GEMINI_VERTEX=
VERTEX_GEMMA_MODEL=

# Agent loop model slots (multi-step tool calling)
MODEL_AGENT_PRIMARY=
MODEL_VOICE_POLISH=
AGENT_COMPLEX_MODEL=
AGENT_ALLOW_COMPLEX_MODEL=true
AGENT_ESCALATE_AFTER_STEPS=3
AGENT_MAX_STEPS=10

# Optional Fireworks-backed retrieval/rerank + LLM capacity fallback
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_FALLBACK_ENABLED=true
FIREWORKS_FALLBACK_MODEL=accounts/fireworks/models/qwen3p7-plus
EMBEDDING_PROVIDER=
FIREWORKS_EMBEDDING_MODEL=fireworks/qwen3-embedding-8b
FIREWORKS_RERANKER_MODEL=fireworks/qwen3-reranker-8b
FIREWORKS_RERANKER_ENABLED=false
RAG_MCP_RERANK_ENABLED=false

# WhatsApp Cloud API (required)
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Dashboard bridge
INTERNAL_API_SECRET=replace-with-a-long-random-string
INTERNAL_API_ALLOW_PRIVATE=0
APP_BASE_URL=http://127.0.0.1:43100
DASHBOARD_BASE_URL=http://127.0.0.1:43101
# Required for manual dashboard/backend launches that accept files: set one
# absolute, writable directory visible at the identical path to both processes.
# Ari Desktop sets this automatically; Docker Compose uses
# /app/.ari-session-attachments. Relative paths are unsafe because the two
# processes have different working directories.
ARI_SESSION_ATTACHMENT_DIR=
ARI_AGENT_FILE_MAX_COUNT=10
ARI_AGENT_FILE_MAX_BYTES=26214400
ARI_AGENT_FILE_TOTAL_MAX_BYTES=52428800

# Manual meeting recording and retained private audio
ASSEMBLYAI_API_KEY=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional when using an S3-compatible provider other than Cloudflare R2
S3_REGION=auto

# OAuth/token encryption. Required before enabling Google/Microsoft OAuth in production.
ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Web/desktop sign-in callback. Use the public HTTPS dashboard URL on AWS.
GOOGLE_DASHBOARD_REDIRECT_URI=http://127.0.0.1:43101/api/auth/google/callback
# Login persists across desktop restarts. Range: 1-3650 days.
ARI_SESSION_DAYS=365
# Local QA only. Never enable this in a public desktop build.
ARI_DESKTOP_AUTH_BYPASS=false
# Used by CI when building the public thin-client installer. Keep unset for
# local source development, which starts the loopback backend and dashboard.
ARI_DESKTOP_DASHBOARD_URL=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# Optional integrations
EXA_API_KEY=
LEAD_ENRICHMENT_ENABLED=false
LEAD_ENRICHMENT_ALLOWLIST=
LEAD_ENRICHMENT_DAILY_BUDGET_USD=5
LEAD_ENRICHMENT_MONTHLY_BUDGET_USD=25
FIRECRAWL_API_KEY=
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Ops switches
DISABLE_BACKGROUND_JOBS=false
DISABLE_OUTBOUND_MESSAGES=false

# Entity context layer (agentic OS substrate)
# LLM fact extraction after each meeting (linking is always on and free)
ENTITY_EXTRACTION_ENABLED=true
# Auto-send numbered action proposals after each completed meeting
MEETING_ACTIONS_AUTO=true

# Agentic loop — ON by default (the multi-step agent loop is the primary
# brain; single-shot intent detection remains the automatic fallback when
# the loop fails). Set AGENTIC_MODE_ALL=false as the kill switch to revert
# everyone to single-shot; AGENTIC_MODE_PHONES then re-enables specific
# numbers for staged rollout.
AGENTIC_MODE_ALL=true
AGENTIC_MODE_PHONES=

# analyze_file: PDFs use OpenRouter's file-parser plugin first. Other document
# types retain OpenAI/Anthropic fallbacks.
FILE_ANALYSIS_PROVIDER=
OPENROUTER_PDF_ENGINE=cloudflare-ai
OPENROUTER_FILE_TIMEOUT_MS=120000
OPENAI_FILE_ANALYSIS_MODEL=gpt-4.1-mini
ANTHROPIC_FILE_ANALYSIS_MODEL=claude-sonnet-4-6

# Codex App Server is used only when the desktop provider is explicitly Codex.
# Ari AI uses provider-neutral Agno; direct Codex login is an explicit mode.
ARI_SHARED_APP_SERVER=true
# After Stop, wait briefly for an in-flight Codex business tool to settle.
# If it does not, the run is reported partial/unknown, never clean-cancelled.
ARI_CODEX_CANCEL_DRAIN_MS=2000

# Google verifies Ari identity first; the sign-in flow then hands Google app
# authorization to Composio so credentials and refresh tokens stay managed.
COMPOSIO_API_KEY=
# Optional: defaults to ENCRYPTION_KEY and is used only to pseudonymize Ari user IDs.
COMPOSIO_USER_ID_SECRET=
COMPOSIO_GMAIL_AUTH_CONFIG_ID=
# One managed Google Workspace connection used by Ari's existing Google clients.
# Google products use separate Composio-managed auth configs. Do not combine
# their scopes into one config: Google can block an unverified cross-product grant.
COMPOSIO_GOOGLE_CALLBACK_URL=http://localhost:43100/auth/google/composio-callback
COMPOSIO_GOOGLE_CALENDAR_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_DRIVE_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_TASKS_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_DOCS_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_SHEETS_AUTH_CONFIG_ID=
COMPOSIO_GOOGLE_SLIDES_AUTH_CONFIG_ID=

# Native multimodal (file/image/PDF) turns use the Vertex native API.
# Claude/Gemini native endpoints are region-bound; "global" is not valid there,
# so this falls back to us-central1 unless set.
ARI_VERTEX_MULTIMODAL_LOCATION=
# Compound-request decomposition (parallel subtasks). Set false to disable.
ARI_COMPOUND_REQUESTS=true
# Per-conversation Postgres advisory lock. Leave false on a transaction-mode
# pooler (Supabase :6543) where session locks leak; enable only for
# multi-instance deployments on a DIRECT connection.
ARI_PG_CONVERSATION_LOCK=false
